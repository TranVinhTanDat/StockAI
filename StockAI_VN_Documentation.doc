    line-height: 1.8;
  }
  .cover-meta {
    font-size: 10pt;
    color: #7a8ba0;
    border-top: 1px solid #e0e8f0;
    padding-top: 24px;
    margin-top: 60px;
  }
  .cover-meta table {
    margin: 0 auto;
    border: none;
  }
  .cover-meta td {
    padding: 4px 20px;
    border: none;
    text-align: center;
  }
  .cover-badge {
    display: inline-block;
    background: #e8fdf8;
    color: #00a88a;
    border: 1px solid #00d4aa;
    border-radius: 20px;
    padding: 6px 20px;
    font-size: 10pt;
    font-weight: 600;
    margin: 4px;
    letter-spacing: 0.5px;
  }

  /* ── Table of Contents ── */
  .toc-page {
    page-break-after: always;
    padding: 40px 0;
  }
  .toc-title {
    font-size: 22pt;
    font-weight: 800;
    color: #1a1a2e;
    border-bottom: 3px solid #00d4aa;
    padding-bottom: 12px;
    margin-bottom: 32px;
  }
  .toc-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 6px 0;
    border-bottom: 1px dotted #c0d0e0;
    font-size: 11pt;
  }
  .toc-item.h1 { font-weight: 700; color: #1a1a2e; font-size: 12pt; margin-top: 12px; }
  .toc-item.h2 { padding-left: 24px; color: #3a4a5a; }
  .toc-item.h3 { padding-left: 48px; color: #5a6a7a; font-size: 10pt; }
  .toc-page-num { color: #7a8ba0; font-size: 10pt; }

  /* ── Headings ── */
  h1 {
    font-size: 20pt;
    font-weight: 900;
    color: #1a1a2e;
    border-left: 5px solid #00d4aa;
    padding-left: 16px;
    margin-top: 36px;
    margin-bottom: 16px;
    page-break-before: always;
  }
  h1:first-of-type { page-break-before: avoid; }
  h2 {
    font-size: 14pt;
    font-weight: 800;
    color: #1e3050;
    margin-top: 28px;
    margin-bottom: 12px;
    padding-bottom: 6px;
    border-bottom: 1.5px solid #c0d8f0;
  }
  h3 {
    font-size: 12pt;
    font-weight: 700;
    color: #2a4060;
    margin-top: 20px;
    margin-bottom: 8px;
  }
  h4 {
    font-size: 11pt;
    font-weight: 700;
    color: #00a88a;
    margin-top: 16px;
    margin-bottom: 6px;
  }

  /* ── Body Text ── */
  p { margin-bottom: 10px; text-align: justify; }
  li { margin-bottom: 5px; }

  /* ── Code Blocks ── */
  pre {
    background: #f4f8ff;
    border: 1px solid #c8d8f0;
    border-left: 4px solid #00d4aa;
    border-radius: 4px;
    padding: 14px 18px;
    font-family: "Courier New", monospace;
    font-size: 9pt;
    color: #1a3050;
    overflow-x: auto;
    margin: 14px 0;
    line-height: 1.5;
    white-space: pre-wrap;
  }
  code {
    background: #eef4ff;
    border: 1px solid #c0d4f0;
    border-radius: 3px;
    padding: 1px 6px;
    font-family: "Courier New", monospace;
    font-size: 9.5pt;
    color: #1a3a6a;
  }

  /* ── Tables ── */
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 16px 0;
    font-size: 10.5pt;
  }
  th {
    background: #1a3050;
    color: #ffffff;
    padding: 10px 14px;
    text-align: left;
    font-weight: 700;
    font-size: 10pt;
  }
  td {
    padding: 8px 14px;
    border-bottom: 1px solid #e0ecf8;
    vertical-align: top;
  }
  tr:nth-child(even) td { background: #f5faff; }
  tr:hover td { background: #eaf4ff; }

  /* ── Callout Boxes ── */
  .box-info {
    background: #e8f8f5;
    border: 1px solid #00d4aa;
    border-left: 4px solid #00d4aa;
    border-radius: 4px;
    padding: 14px 18px;
    margin: 16px 0;
  }
  .box-warn {
    background: #fff8e8;
    border: 1px solid #f5a623;
    border-left: 4px solid #f5a623;
    border-radius: 4px;
    padding: 14px 18px;
    margin: 16px 0;
  }
  .box-danger {
    background: #fff0f3;
    border: 1px solid #f43f5e;
    border-left: 4px solid #f43f5e;
    border-radius: 4px;
    padding: 14px 18px;
    margin: 16px 0;
  }
  .box-title {
    font-weight: 700;
    font-size: 10pt;
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* ── Badges / Tags ── */
  .badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 9pt;
    font-weight: 600;
    margin: 2px;
  }
  .badge-green { background: #e8fdf8; color: #00a88a; border: 1px solid #00d4aa; }
  .badge-blue  { background: #e8f0ff; color: #2a6ae0; border: 1px solid #6090f0; }
  .badge-gold  { background: #fff8e8; color: #c07820; border: 1px solid #f5a623; }
  .badge-red   { background: #fff0f3; color: #c0203a; border: 1px solid #f43f5e; }
  .badge-gray  { background: #f0f4f8; color: #4a5a6a; border: 1px solid #b0c0d0; }

  /* ── Section Divider ── */
  .section-divider {
    text-align: center;
    color: #c0d0e0;
    font-size: 18pt;
    margin: 20px 0;
  }

  /* ── Stats Row ── */
  .stats-row {
    display: flex;
    gap: 20px;
    margin: 20px 0;
    flex-wrap: wrap;
  }
  .stat-card {
    flex: 1;
    min-width: 120px;
    background: #f5faff;
    border: 1px solid #c8daf0;
    border-top: 3px solid #00d4aa;
    border-radius: 6px;
    padding: 14px 16px;
    text-align: center;
  }
  .stat-number {
    font-size: 22pt;
    font-weight: 900;
    color: #00a88a;
    line-height: 1;
    margin-bottom: 4px;
  }
  .stat-label {
    font-size: 9pt;
    color: #5a6a7a;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* ── Feature Grid ── */
  .feature-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 20px 0;
  }
  .feature-card {
    background: #f8fbff;
    border: 1px solid #dceaf8;
    border-radius: 8px;
    padding: 16px 18px;
  }
  .feature-icon { font-size: 18pt; margin-bottom: 8px; }
  .feature-name { font-weight: 700; font-size: 11pt; color: #1a2e4a; margin-bottom: 6px; }
  .feature-desc { font-size: 10pt; color: #4a5a6a; line-height: 1.5; }

  /* ── File Tree ── */
  .file-tree {
    background: #f2f6ff;
    border: 1px solid #c0d4f0;
    border-radius: 6px;
    padding: 16px 20px;
    font-family: "Courier New", monospace;
    font-size: 9pt;
    line-height: 1.7;
    color: #1a2a3a;
  }
  .file-tree .dir  { color: #1a5aa0; font-weight: 700; }
  .file-tree .file { color: #2a4a2a; }
  .file-tree .note { color: #7a8ba0; font-style: italic; }

  /* ── API Route Table ── */
  .method-get  { background: #e8f8e8; color: #1a7a1a; border: 1px solid #60c060; border-radius: 3px; padding: 1px 8px; font-size: 9pt; font-weight: 700; }
  .method-post { background: #e8eeff; color: #1a2a9a; border: 1px solid #6070d0; border-radius: 3px; padding: 1px 8px; font-size: 9pt; font-weight: 700; }

  /* ── Footer ── */
  .page-footer {
    margin-top: 60px;
    padding-top: 16px;
    border-top: 1px solid #c0d0e0;
    font-size: 9pt;
    color: #7a8ba0;
    text-align: center;
  }
</style>
