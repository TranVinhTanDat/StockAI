  </tr>
  <tr>
    <td><strong>Frontend Framework</strong></td>
    <td>Next.js</td>
    <td>14.2.x (App Router)</td>
    <td>SSR/SSG, file-based routing, API routes</td>
  </tr>
  <tr>
    <td><strong>Ngôn ngữ</strong></td>
    <td>TypeScript</td>
    <td>5.9.x (strict mode)</td>
    <td>Type safety toàn bộ codebase</td>
  </tr>
  <tr>
    <td><strong>Styling</strong></td>
    <td>Tailwind CSS</td>
    <td>3.4.x</td>
    <td>Utility-first CSS, dark theme custom</td>
  </tr>
  <tr>
    <td><strong>UI Primitives</strong></td>
    <td>Radix UI</td>
    <td>1.x/2.x</td>
    <td>Accessible components (Dialog, Tabs, Select…)</td>
  </tr>
  <tr>
    <td><strong>Charts</strong></td>
    <td>Lightweight Charts</td>
    <td>5.1.0</td>
    <td>Biểu đồ nến OHLCV chuyên nghiệp</td>
  </tr>
  <tr>
    <td><strong>AI Engine</strong></td>
    <td>Claude AI (Anthropic)</td>
    <td>claude-opus-4-6</td>
    <td>Phân tích cổ phiếu, chat, tối ưu danh mục</td>
  </tr>
  <tr>
    <td><strong>Database</strong></td>
    <td>Supabase (PostgreSQL)</td>
    <td>2.98.x</td>
    <td>Lưu danh mục, phân tích, cảnh báo</td>
  </tr>
  <tr>
    <td><strong>Local Storage</strong></td>
    <td>localStorage API</td>
    <td>-</td>
    <td>Fallback khi chưa có Supabase env</td>
  </tr>
  <tr>
    <td><strong>Data Fetching</strong></td>
    <td>SWR</td>
    <td>2.4.x</td>
    <td>Stale-while-revalidate, auto-refresh</td>
  </tr>
  <tr>
    <td><strong>Authentication</strong></td>
    <td>JWT (jose)</td>
