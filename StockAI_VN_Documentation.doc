    <td>300s</td>
  </tr>
  <tr>
    <td><span class="method-get">GET</span></td>
    <td><code>/api/priceboard</code></td>
    <td>Giá realtime cho bảng giá. Params: <code>group</code>, <code>symbols</code>, <code>withIndex</code></td>
    <td>no-store</td>
  </tr>
  <tr>
    <td><span class="method-get">GET</span></td>
    <td><code>/api/fundamental</code></td>
    <td>Dữ liệu tài chính cơ bản. Params: <code>symbol</code></td>
    <td>3600s</td>
  </tr>
  <tr>
    <td><span class="method-post">POST</span></td>
    <td><code>/api/analyze</code></td>
    <td>Phân tích AI đầy đủ. Body: <code>{ symbol }</code></td>
    <td>no-cache</td>
  </tr>
  <tr>
    <td><span class="method-post">POST</span></td>
    <td><code>/api/chat-stock</code></td>
    <td>Chat AI về cổ phiếu. Body: <code>{ symbol, messages[] }</code></td>
    <td>no-cache</td>
  </tr>
  <tr>
    <td><span class="method-post">POST</span></td>
    <td><code>/api/optimize</code></td>
    <td>AI tối ưu danh mục. Body: <code>{ holdings[], cash }</code></td>
    <td>no-cache</td>
  </tr>
  <tr>
    <td><span class="method-post">POST</span></td>
    <td><code>/api/predict</code></td>
    <td>AI dự đoán top cổ phiếu. Body: <code>{ style }</code></td>
    <td>no-cache</td>
  </tr>
  <tr>
    <td><span class="method-get">GET</span></td>
    <td><code>/api/news</code></td>
    <td>Tin tức + sentiment. Params: <code>symbol</code> (optional)</td>
    <td>600s</td>
  </tr>
  <tr>
    <td><span class="method-post">POST</span></td>
    <td><code>/api/news-summary</code></td>
    <td>AI tóm tắt tin tức hôm nay</td>
    <td>3600s</td>
  </tr>
  <tr>
    <td><span class="method-get">GET</span></td>
    <td><code>/api/market-index</code></td>
    <td>VN-Index, HNX-Index, breadth</td>
    <td>60s</td>
  </tr>
  <tr>
    <td><span class="method-get">GET</span></td>
    <td><code>/api/market-heatmap</code></td>
    <td>Dữ liệu heat map thị trường</td>
    <td>120s</td>
  </tr>
  <tr>
    <td><span class="method-get">GET</span></td>
    <td><code>/api/company</code></td>
    <td>Hồ sơ công ty, lịch sử tài chính</td>
    <td>3600s</td>
  </tr>
  <tr>
    <td><span class="method-get">GET</span></td>
    <td><code>/api/analyst-reports</code></td>
    <td>Danh sách báo cáo phân tích PDF</td>
    <td>3600s</td>
  </tr>
  <tr>
    <td><span class="method-post">POST</span></td>
    <td><code>/api/report-analyze</code></td>
    <td>AI phân tích báo cáo PDF</td>
    <td>no-cache</td>
  </tr>
  <tr>
    <td><span class="method-get">GET</span></td>
    <td><code>/api/exchange</code></td>
    <td>Tỷ giá USD/VND, EUR/VND</td>
    <td>300s</td>
  </tr>
  <tr>
    <td><span class="method-post">POST</span></td>
    <td><code>/api/push/subscribe</code></td>
    <td>Đăng ký push notification</td>
    <td>-</td>
  </tr>
  <tr>
    <td><span class="method-post">POST</span></td>
    <td><code>/api/auth/login</code></td>
    <td>Đăng nhập, trả JWT cookie</td>
    <td>-</td>
  </tr>
  <tr>
    <td><span class="method-post">POST</span></td>
    <td><code>/api/auth/register</code></td>
