### THAY ĐỔI 9 — Sparkline trong WatchlistTable

#### [MODIFY] [components/dashboard/WatchlistTable.tsx](file:///c:/Users/culua/Downloads/D_ToolStock/components/dashboard/WatchlistTable.tsx)

**Thêm cột mới** giữa "KL" và nút "Phân tích":

```typescript
// Inline component mới
function Sparkline({ symbol }: { symbol: string }) {
  const { data } = useSWR<HistoryData>(
    `/api/history?symbol=${symbol}&days=7`,
    fetcher,
    { revalidateOnFocus: false, dedupingInterval: 300000 }
  )
  if (!data?.candles?.length) return <span className="text-muted text-xs">---</span>

  const prices = data.candles.map(c => c.close)
  const min = Math.min(...prices)
  const max = Math.max(...prices)
  const range = max - min || 1
  const w = 60, h = 24
  const trend = prices[prices.length - 1] >= prices[0]

  const points = prices.map((p, i) => {
    const x = (i / Math.max(prices.length - 1, 1)) * w
    const y = h - ((p - min) / range) * (h - 4) - 2
    return `${x},${y}`
  }).join(' ')

  return (
    <svg width={w} height={h} className="inline-block">
      <polyline points={points} fill="none"
        stroke={trend ? '#00d4aa' : '#f43f5e'} strokeWidth="1.5" />
    </svg>
  )
}
```

